# Cassandra Configuration
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=ent_db

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ent-courses

# Authentication
SECRET_KEY=your-secret-key-change-in-production-123456789
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Ollama Configuration
OLLAMA_URL=http://ollama:11434
MODEL_NAME=llama3

# Service URLs (internal)
AUTH_SERVICE_URL=http://auth-service:8001
FILE_SERVICE_URL=http://file-management-service:8002
DOWNLOAD_SERVICE_URL=http://download-service:8003
ADMIN_SERVICE_URL=http://admin-service:8004
CHATBOT_SERVICE_URL=http://chatbot-service:8005

# Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443
